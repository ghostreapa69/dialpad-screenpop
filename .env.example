# ============================================================
# Dialpad Screen Pop Middleware - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Port the server listens on
PORT=3500

# Redis connection URL
# In Docker Compose this points to the redis service name
# For local dev, use redis://localhost:6379
REDIS_URL=redis://redis:6379

# Your Dialpad API key (must have screen_pop scope)
DIALPAD_API_KEY=your_dialpad_api_key_here

# The secret you used when creating the Dialpad webhook via API
# Leave blank if you created the webhook without a secret
DIALPAD_WEBHOOK_SECRET=

# Your Salesforce instance URL (no trailing slash)
# Examples:
#   https://yourcompany.lightning.force.com
#   https://yourcompany.my.salesforce.com
SALESFORCE_BASE_URL=https://yourcompany.lightning.force.com

# Optional: shared secret to verify Five9 connector requests
FIVE9_SECRET=

# ============================================================
# Salesforce Connected App (client_credentials OAuth flow)
# Required for Lead-to-Contact conversion
# ============================================================

# Salesforce login endpoint (use https://test.salesforce.com for sandboxes)
SF_LOGIN_URL=https://login.salesforce.com

# Connected App Consumer Key
SF_CLIENT_ID=

# Connected App Consumer Secret
SF_CLIENT_SECRET=
